# AI-SCERN Detection Worker v4.0.0 — Environment Variables
# Copy to .env for local dev. Never commit actual secrets.

# ── Server ────────────────────────────────────────────────────────────────────
PORT=8080
LOG_LEVEL=INFO

# ── Security (CORS) ───────────────────────────────────────────────────────────
ALLOWED_ORIGINS=https://aiscern.com,https://www.aiscern.com
# For local dev, add: http://localhost:3000

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:pass@host:5432/dbname
REDIS_URL=redis://user:pass@host:6379/0

# ── AI APIs ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx

# ── OCR (set by Dockerfile; only override if tessdata is in a non-default path) ──
TESSDATA_PREFIX=/usr/share/tesseract-ocr/4.00/tessdata

# ── Request Limits ────────────────────────────────────────────────────────────
MAX_IMAGE_SIZE_MB=10
MAX_TEXT_LENGTH=10000

# ── Hardware ──────────────────────────────────────────────────────────────────
# Set to "true" only on GPU-enabled instances (DO GPU droplets).
# When false, /diffusion-inversion and /diffusion-snapback return 503.
GPU_ENABLED=false
MODEL_CACHE_DIR=/tmp/aiscern-models
