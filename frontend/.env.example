# ─────────────────────────────────────────────────────────────────────────────
# Aiscern — Environment Variables
# Copy this file to .env.local and fill in your values.
# Never commit .env.local to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── CLERK AUTH (Required) ─────────────────────────────────────────────────────
# Get from: https://dashboard.clerk.com → your app → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_...
CLERK_SECRET_KEY=sk_live_...

# ── SUPABASE (Required — metadata store only, no file storage) ────────────────
# Get from: https://supabase.com/dashboard → your project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── GEMINI AI (Required — primary detection engine) ───────────────────────────
# Get from: https://aistudio.google.com/app/apikey
# Free tier: 1,500 requests/day — enough for significant traffic
# ── SEMANTIC RAG — Vision APIs (Layer 6: AI Image Detection) ─────────────────
# Cascade: Grok → Gemini → OpenRouter. At least ONE must be set.
# Primary  → Grok Vision (xAI)     — console.x.ai
GROK_API_KEY=xai-...
# Fallback → Gemini Flash (Google)  — aistudio.google.com/app/apikey
GEMINI_API_KEY=AIza...
# Final    → OpenRouter free tier   — openrouter.ai/settings/keys
OPENROUTER_API_KEY=sk-or-...

# ── CLOUDFLARE R2 (Required — file storage, replaces Supabase storage) ────────
# Create an R2 bucket in: https://dash.cloudflare.com → R2 Object Storage
# Create API token: Manage R2 → API Tokens → Create token (Object Read & Write)
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=aiscern-uploads
# Optional: public URL if bucket has public access enabled
R2_PUBLIC_URL=https://uploads.aiscern.com

# ── CLOUDFLARE D1 (Required — pipeline state) ─────────────────────────────────
# From: https://dash.cloudflare.com → Workers & Pages → D1
CLOUDFLARE_API_TOKEN=your-cloudflare-api-token
CLOUDFLARE_ACCOUNT_ID=your-cloudflare-account-id
CLOUDFLARE_D1_DATABASE_ID=50f5e26a-c794-4cfa-b2b7-2bbd1d7c045c

# ── NVIDIA NIM (Optional — video deepfake detection) ──────────────────────────
# Get from: https://build.nvidia.com → Get API Key
# Without this key, video detection falls back to metadata heuristics.
NVIDIA_API_KEY=nvapi-...

# ── HUGGING FACE (Optional — enriches text/image/audio detection) ─────────────
# Get from: https://huggingface.co/settings/tokens
# Without this key, Gemini handles detection standalone.
# With this key, HF models run in parallel and enrich the ensemble.
HUGGINGFACE_API_TOKEN=hf_...

# ── INNGEST (Required for background jobs) ────────────────────────────────────
# Install Vercel integration first: https://vercel.com/integrations/inngest
# Keys are auto-injected by the integration. For local dev:
INNGEST_EVENT_KEY=local
INNGEST_SIGNING_KEY=signkey-prod-...

# ── INTERNAL API SECRET (Required — server-to-server auth bypass) ─────────────
# Any strong random string. Used by chat route to call detect routes without credits.
INTERNAL_API_SECRET=aiscern-internal-2026-change-this

# ── XPAY (Optional — payments, PKR + international) ──────────────────────────
# Get from: https://xpay.com.pk/docs
XPAY_API_URL=https://api.xpay.com.pk/v2
XPAY_API_KEY=
XPAY_SECRET_KEY=
XPAY_MERCHANT_ID=

# ── DEPRECATED / UNUSED ───────────────────────────────────────────────────────
# These were used in earlier versions. Do NOT add them — they are not read.
# Firebase → replaced by Clerk
# Stripe   → replaced by XPay
# AWS Bedrock → replaced by Gemini

# ── UPSTASH REDIS (Required for production rate limiting + result caching) ────
# Create free instance: https://upstash.com → Create Database → Redis
UPSTASH_REDIS_REST_URL=https://...upstash.io
UPSTASH_REDIS_REST_TOKEN=AX...

# ── CLOUDFLARE WORKER PROXY (Optional — for web scraper anti-blocking) ────────
# Deploy cf-workers/proxy-worker.ts to Cloudflare Workers
CF_PROXY_URL=https://proxy.aiscern.workers.dev
CF_PROXY_SECRET=aiscern-proxy-secret-change-this

# ── STATIC PROXY POOL (Optional — fallback for web scraper) ──────────────────
# Comma-separated list: http://user:pass@host:port,...
PROXY_POOL=
-e 
# Public API master key — for internal calls and testing
# Generate: openssl rand -hex 32
API_MASTER_KEY=aiscern-api-master-change-this-in-production

# HuggingFace dataset push (used by cf-pipeline and training scripts)
# Same token as HUGGINGFACE_API_TOKEN — both names accepted in hf-analyze.ts
HF_TOKEN=hf_your_token_here
HF_DATASET_REPO=your-username/detectai-dataset

# Email (Resend — used for contact form / notifications)
# Get from: resend.com
RESEND_API_KEY=re_your_key_here

# Cloudflare Worker URLs (distributed scraping pipeline)
# Set these to your deployed cf-pipeline Worker endpoints
WORKER_A_URL=https://worker-a.your-account.workers.dev
WORKER_B_URL=https://worker-b.your-account.workers.dev
WORKER_C_URL=https://worker-c.your-account.workers.dev
WORKER_D_URL=https://worker-d.your-account.workers.dev
WORKER_E_URL=https://worker-e.your-account.workers.dev
