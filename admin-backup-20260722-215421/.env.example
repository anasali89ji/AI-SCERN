# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Admin Auth
ADMIN_PASSWORD_BCRYPT=$2a$12$... (generate with bcrypt)
ADMIN_SESSION_SECRET=your-32-char-secret-min

# Redis (Upstash)
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token

# Email (Resend)
RESEND_API_KEY=re_...
ADMIN_SUPPORT_EMAIL=support@aiscern.com

# HuggingFace
HUGGINGFACE_API_TOKEN=hf_...
HF_DATASET_REPO=your-username/your-dataset

# Cloudflare (Pipeline)
CLOUDFLARE_API_TOKEN=...
CLOUDFLARE_ACCOUNT_ID=...
CLOUDFLARE_D1_DB_ID=...

# App
NEXT_PUBLIC_APP_URL=https://aiscern.com
